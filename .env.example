# ========================================
# StandMe OS — Environment Configuration
# Copy this to .env and fill in your values
# ========================================

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
MO_TELEGRAM_ID=6140480367
MO_BACKUP_TELEGRAM_ID=517107884
HADEER_TELEGRAM_ID=5135842073
BASSEL_TELEGRAM_USERNAME=bassel_al_hussein

# Google Service Account
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----"

# Google Sheet IDs
SHEET_LEAD_MASTER=your_sheet_id
SHEET_LESSONS_LEARNED=your_sheet_id
SHEET_OUTREACH_QUEUE=your_sheet_id
SHEET_OUTREACH_LOG=your_sheet_id
SHEET_TECHNICAL_DEADLINES=your_sheet_id
SHEET_CONTRACTOR_DB=your_sheet_id
SHEET_DRIVE_INDEX=your_sheet_id
SHEET_CROSS_AGENT_HUB=your_sheet_id
SHEET_SYSTEM_LOG=your_sheet_id
SHEET_CAMPAIGN_SALES=your_sheet_id
SHEET_KNOWLEDGE_BASE=your_sheet_id

# Trello
TRELLO_API_KEY=your_trello_api_key
TRELLO_TOKEN=your_trello_token
TRELLO_BOARD_SALES_PIPELINE=your_board_id
TRELLO_BOARD_DESIGN=your_board_id
TRELLO_BOARD_OPERATION=your_board_id
TRELLO_BOARD_PRODUCTION=your_board_id

# Woodpecker
WOODPECKER_API_KEY=your_woodpecker_api_key
WOODPECKER_FROM_NAME=Mo
# WOODPECKER_FROM_EMAIL=info@standme.de  (defaults to SEND_FROM_EMAIL)
# WOODPECKER_CAMPAIGN_ID=12345  (optional override — agent auto-creates/selects campaigns)

# Anthropic Claude (for Brain agent reasoning)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Gmail
GMAIL_LABEL=standme-inquiries
SEND_FROM_EMAIL=info@standme.de

# Google Drive — agent output folder
# Set this to your existing StandMe folder ID so all agent-created docs land there
# (NOT in the service account's personal Drive — use YOUR folder, shared with the service account)
# Get the ID from the folder URL: drive.google.com/drive/folders/FOLDER_ID_HERE
DRIVE_FOLDER_AGENTS=19FU-EKvNdpiOjjUBWafQWVoo2YTGDZsl
# Extra emails outside standme.de domain to share files with silently (optional, comma-separated)
# TEAM_SHARE_EMAILS=partner@gmail.com,contractor@example.com
